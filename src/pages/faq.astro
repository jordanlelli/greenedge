---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FaqsSection from "../components/sections/FaqsSection.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import { site } from "../config";

const businessName = site.business?.name || "GreenEdge";
const title = `${site.faqs?.heading || "FAQ"} — ${businessName}`;
const description =
  site.faqs?.items?.[0]?.answer ||
  site.business?.shortDescription ||
  site.business?.tagline;
---

<Layout title={title} description={description} pageType="other">
  <Header />
  <main>
    <FaqsSection />
    <ContactSection />
  </main>
  <Footer />
</Layout>
