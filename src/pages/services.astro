---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../config";

const services = site.services || {};
const items = services.items || [];
const businessName = site.business?.name || "GreenEdge Property Care";

const title = `Services | ${businessName}`;
const description =
  site.business?.shortDescription ||
  site.seo?.description ||
  `${businessName} — gardening, pressure washing, and gutter cleaning across Adelaide.`;

const pageEyebrow = services.pageEyebrow || "Services";
const pageHeading = services.pageHeading || "Everything we do";
const pageSubhead = services.subhead || "";
---

<Layout title={title} description={description} pageType="services">
  <Header />

  <main class="bg-paper text-ink">
    <section class="border-b border-white/10 bg-brand py-14 text-white lg:py-16">
      <div class="mx-auto max-w-6xl px-4 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-wide text-highlight">{pageEyebrow}</p>
        <h1 class="mt-2 max-w-3xl font-heading text-4xl font-semibold tracking-tight sm:text-5xl">
          {pageHeading}
        </h1>
        {pageSubhead && (
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/75">{pageSubhead}</p>
        )}
      </div>
    </section>

    {items.map((service: any, index: number) => {
      const imageRight = index % 2 === 0;
      const body = service.longDescription || service.description || "";
      const paragraphs = body.split(/\n\n+/).filter(Boolean);
      const includes: string[] = service.includes || [];
      const bgClass = index % 2 === 0 ? "bg-paper" : "bg-tint";

      return (
        <section class={`py-16 lg:py-20 ${bgClass}`}>
          <div class="mx-auto max-w-6xl px-4 lg:px-8">
            <div
              class:list={[
                "grid items-center gap-10 lg:grid-cols-2 lg:gap-16",
                imageRight && "lg:[&>div:first-child]:order-2 lg:[&>div:last-child]:order-1",
              ]}
            >
              <div class="min-w-0">
                <img
  			src={service.image}
 			alt={service.imageAlt || service.title}
  			width="600"
  			height="450"
  			loading={index === 0 ? "eager" : "lazy"}
  			onerror="this.style.display='none'; this.parentElement.classList.add('bg-gradient-to-br', 'from-brand/20', 'to-brand-dark/30')"
  			class="aspect-[4/3] w-full rounded-2xl border border-border object-cover"
		/>
              </div>

              <div class="min-w-0">
                <h2 class="font-heading text-3xl font-semibold tracking-tight text-brand sm:text-4xl">
                  {service.title}
                </h2>

                <div class="mt-5 space-y-4 text-base leading-relaxed text-muted">
                  {paragraphs.map((paragraph: string) => (
                    <p>{paragraph}</p>
                  ))}
                </div>

                {includes.length > 0 && (
                  <ul class="mt-8 space-y-3">
                    {includes.map((item: string) => (
                      <li class="flex items-start gap-3 text-sm leading-relaxed text-ink">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="mt-0.5 h-4 w-4 shrink-0 text-highlight"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          aria-hidden="true"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          </div>
        </section>
      );
    })}

    <section class="border-t border-brand/10 bg-tint py-16 lg:py-20">
      <div class="mx-auto max-w-2xl px-4 text-center lg:px-8">
        <h2 class="font-heading text-2xl font-semibold text-brand sm:text-3xl">
          Want a quote on any of these?
        </h2>
        <p class="mt-3 text-muted">
          Free, no obligation. We come out and walk the garden with you.
        </p>
        <a
          href="/#contact"
          class="mt-6 inline-flex rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-accent/90"
        >
          Get a free quote
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
