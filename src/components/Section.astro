---
interface Props {
  id?: string;
  title?: string;
  eyebrow?: string;
  subtitle?: string;
  variant?: "light" | "dark" | "tinted" | "paper";
  align?: "left" | "center";
}

const {
  id,
  title,
  eyebrow,
  subtitle,
  variant = "paper",
  align = "center",
} = Astro.props;

const bgClass = {
  light: "bg-white",
  dark: "bg-brand-dark text-white",
  tinted: "bg-tint",
  paper: "bg-paper",
}[variant];

const alignClass = align === "center" ? "text-center" : "text-left";
const subtitleColor =
  variant === "dark" ? "text-white/70" : "text-gray-600";
const eyebrowColor = "text-highlight";
const titleColor =
  variant === "dark" ? "text-white" : "text-brand";
---

<section id={id} class={`${bgClass} py-20 lg:py-24`}>
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    {(eyebrow || title || subtitle) && (
      <div class={`${alignClass} ${align === "center" ? "mx-auto max-w-2xl" : ""}`}>
        {eyebrow && (
          <span class={`text-sm font-semibold uppercase tracking-wide ${eyebrowColor}`}>{eyebrow}</span>
        )}
        {title && (
          <h2 class={`mt-2 font-heading text-3xl font-semibold tracking-tight sm:text-4xl ${titleColor}`}>
            {title}
          </h2>
        )}
        {subtitle && <p class={`mt-3 text-lg leading-relaxed ${subtitleColor}`}>{subtitle}</p>}
      </div>
    )}
    <div class={eyebrow || title || subtitle ? "mt-12" : ""}>
      <slot />
    </div>
  </div>
</section>
