---
import Section from "../Section.astro";
import { site } from "../../config";

const items = site.testimonials || [];
---

<Section id="testimonials" eyebrow="Reviews" title="What clients say" variant="tinted">
  <div class="grid gap-6 md:grid-cols-3">
    {items.map((review: any) => (
      <blockquote class="flex flex-col rounded-2xl border border-brand/10 bg-white p-6">
        <p class="flex-1 text-sm leading-relaxed text-gray-600">&ldquo;{review.quote}&rdquo;</p>
        <footer class="mt-4 border-t border-brand/5 pt-4">
          <cite class="not-italic">
            <span class="font-semibold text-brand">{review.name}</span>
            {review.location && (
              <span class="text-sm text-gray-500"> · {review.location}</span>
            )}
          </cite>
        </footer>
      </blockquote>
    ))}
  </div>
</Section>
