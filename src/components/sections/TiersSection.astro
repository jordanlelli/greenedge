---
import Section from "../Section.astro";
import BotanicalDivider from "../BotanicalDivider.astro";
import { site } from "../../config";

const data = site.tiers || {};
const items = data.items || [];
---

<Section
  id="tiers"
  eyebrow={data.eyebrow}
  title={data.heading}
  subtitle={data.subhead}
  variant="tinted"
>
  <div class="grid gap-6 md:grid-cols-3">
    {items.map((tier: any) => {
      const total = tier.of || 3;
      const intensity = tier.intensity || 0;
      return (
        <div class="flex flex-col rounded-2xl border border-brand/15 bg-white p-6">
          <div class="flex items-start justify-between gap-3">
            <h3 class="font-heading text-xl font-semibold text-brand">{tier.title}</h3>
            {tier.emoji && <span class="text-xl" aria-hidden="true">{tier.emoji}</span>}
          </div>

          <div class="mt-4 flex gap-1.5" role="img" aria-label={`Intensity ${intensity} of ${total}`}>
            {Array.from({ length: total }).map((_, i) => (
              <div
                class={`h-2 flex-1 rounded-full ${i < intensity ? "bg-highlight" : "bg-brand/15"}`}
              />
            ))}
          </div>

          {tier.description && (
            <p class="mt-4 flex-1 text-sm leading-relaxed text-gray-600">{tier.description}</p>
          )}
        </div>
      );
    })}
  </div>
</Section>

<BotanicalDivider />
