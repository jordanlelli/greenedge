---
import Section from "../Section.astro";
import { site } from "../../config";

const items = site.whyUs || [];
---

<Section id="why-us" eyebrow="Why GreenEdge" title="Why choose us" variant="tinted">
  <div class="grid gap-6 sm:grid-cols-2">
    {items.map((item: any) => (
      <div class="rounded-2xl border border-brand/10 bg-white p-6">
        <h3 class="font-heading text-lg font-semibold text-brand">{item.title}</h3>
        {item.description && (
          <p class="mt-2 text-sm leading-relaxed text-gray-600">{item.description}</p>
        )}
      </div>
    ))}
  </div>
</Section>
