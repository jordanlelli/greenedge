---
import Section from "../Section.astro";
import { site, formatPhone, fullAddress } from "../../config";

const data = site.contactSection || {};
const form = data.form || {};
const enquiryTypes = site.contact?.enquiryTypes || [];
const fields = form.fields || [];
const showField = (name: string) => fields.includes(name);
---

<Section
  id="contact"
  eyebrow={data.eyebrow}
  title={data.heading}
  subtitle={data.subhead}
  variant="light"
>
  <div class="grid gap-10 lg:grid-cols-5">
    {form.enabled && site.contact?.email && (
      <div class="lg:col-span-3">
        <form
          action={`https://formsubmit.co/${site.contact.email}`}
          method="POST"
          class="space-y-5 rounded-2xl border border-brand/10 bg-white p-6 shadow-sm sm:p-8"
        >
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_subject" value={`New enquiry — ${site.business?.name}`} />

          <div class="grid gap-5 sm:grid-cols-2">
            {showField("name") && (
              <div>
                <label for="name" class="mb-1.5 block text-sm font-medium text-gray-700">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
                />
              </div>
            )}
            {showField("phone") && (
              <div>
                <label for="phone" class="mb-1.5 block text-sm font-medium text-gray-700">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
                />
              </div>
            )}
          </div>

          {showField("email") && (
            <div>
              <label for="email" class="mb-1.5 block text-sm font-medium text-gray-700">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
              />
            </div>
          )}

          {showField("suburb") && (
            <div>
              <label for="suburb" class="mb-1.5 block text-sm font-medium text-gray-700">Suburb</label>
              <input
                type="text"
                id="suburb"
                name="suburb"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
              />
            </div>
          )}

          {showField("enquiryType") && enquiryTypes.length > 0 && (
            <div>
              <label for="enquiryType" class="mb-1.5 block text-sm font-medium text-gray-700">Enquiry type</label>
              <select
                id="enquiryType"
                name="enquiryType"
                class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
              >
                <option value="">Select…</option>
                {enquiryTypes.map((type: string) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>
          )}

          {showField("message") && (
            <div>
              <label for="message" class="mb-1.5 block text-sm font-medium text-gray-700">Tell us about your garden</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full resize-none rounded-xl border border-gray-200 px-4 py-3 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20"
              />
            </div>
          )}

          <button
            type="submit"
            class="rounded-xl bg-brand px-8 py-3.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-dark"
          >
            {form.submitLabel || "Send enquiry"}
          </button>
        </form>
      </div>
    )}

    <div class="space-y-4 lg:col-span-2">
      {site.contact?.phone && (
        <a
          href={`tel:${formatPhone(site.contact.phone)}`}
          class="block rounded-2xl border border-brand/10 bg-paper p-5 transition hover:border-brand/25 hover:shadow-sm"
        >
          <p class="text-sm font-medium text-accent">Prefer to call?</p>
          <p class="mt-1 text-xl font-semibold text-brand">{site.contact.phone}</p>
        </a>
      )}
      {site.contact?.email && (
        <a
          href={`mailto:${site.contact.email}`}
          class="block rounded-2xl border border-brand/10 bg-paper p-5 transition hover:border-brand/25 hover:shadow-sm"
        >
          <p class="text-sm font-medium text-gray-500">Email</p>
          <p class="mt-1 font-semibold text-brand">{site.contact.email}</p>
        </a>
      )}
      {fullAddress() && (
        <div class="rounded-2xl border border-brand/10 bg-paper p-5">
          <p class="text-sm font-medium text-gray-500">Based in</p>
          <p class="mt-1 font-medium text-brand">{fullAddress()}</p>
        </div>
      )}
      {site.contact?.hours && (
        <div class="rounded-2xl border border-brand/10 bg-paper p-5">
          <p class="text-sm font-medium text-gray-500">Hours</p>
          <p class="mt-1 text-sm text-gray-700">{site.contact.hours}</p>
        </div>
      )}
    </div>
  </div>
</Section>
