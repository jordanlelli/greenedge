---
import Section from "../Section.astro";
import { site } from "../../config";

const data = site.story || {};
const cards = data.cards || [];
const paragraphs = (data.body || "").split("\n\n").filter(Boolean);
---

<Section
  id="story"
  eyebrow={data.eyebrow}
  title={data.heading}
  variant="paper"
  align="left"
>
  <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
    <div class="space-y-4 text-gray-600 leading-relaxed">
      {paragraphs.map((p: string) => (
        <p>{p}</p>
      ))}
    </div>

    <div class="grid gap-4 sm:grid-cols-1">
      {cards.map((card: any) => (
        <div class="rounded-2xl border border-brand/10 bg-white p-6">
          {card.type === "badges" ? (
            <>
              <h3 class="font-heading text-lg font-semibold text-brand">{card.title}</h3>
              <div class="mt-4 flex flex-wrap gap-2">
                {card.badges?.map((badge: string) => (
                  <span class="rounded-full bg-brand/5 px-3 py-1.5 text-xs font-semibold text-brand">
                    {badge}
                  </span>
                ))}
              </div>
            </>
          ) : (
            <>
              <div class="flex items-center gap-2">
                {card.emoji && <span class="text-xl" aria-hidden="true">{card.emoji}</span>}
                <h3 class="font-heading text-lg font-semibold text-brand">{card.title}</h3>
              </div>
              {card.description && (
                <p class="mt-2 text-sm leading-relaxed text-gray-600">{card.description}</p>
              )}
            </>
          )}
        </div>
      ))}
    </div>
  </div>
</Section>
