---
import Section from "../Section.astro";
import BotanicalDivider from "../BotanicalDivider.astro";
import { site } from "../../config";

const data = site.services || {};
const items = data.items || [];
---

<Section
  id="services"
  eyebrow={data.eyebrow}
  title={data.heading}
  subtitle={data.subhead}
  variant="paper"
>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((service: any) => (
      <div class="rounded-2xl border border-brand/10 bg-white p-6 transition hover:border-brand/25 hover:shadow-md">
        <h3 class="font-heading text-lg font-semibold text-brand">{service.title}</h3>
        {service.description && (
          <p class="mt-2 text-sm leading-relaxed text-gray-600">{service.description}</p>
        )}
      </div>
    ))}
  </div>
</Section>

<BotanicalDivider />
