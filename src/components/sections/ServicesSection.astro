---
import Section from "../Section.astro";
import BotanicalDivider from "../BotanicalDivider.astro";
import { site } from "../../config";

const data = site.services || {};
const items = data.items || [];
---

<Section
  id="services"
  eyebrow={data.eyebrow}
  title={data.heading}
  subtitle={data.subhead}
  variant="paper"
>
  <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((service: any) => (
      <li class="rounded-xl border border-brand/10 bg-white px-4 py-3">
        <h3 class="font-heading text-base font-semibold text-brand">{service.title}</h3>
        {service.description && (
          <p class="mt-1 text-sm leading-relaxed text-gray-600">{service.description}</p>
        )}
      </li>
    ))}
  </ul>

  <div class="mt-10 text-center">
    <a
      href="/services"
      class="inline-flex items-center justify-center rounded-xl bg-brand px-7 py-3.5 text-sm font-semibold text-white transition hover:bg-brand-dark"
    >
      View all services
    </a>
  </div>
</Section>

<BotanicalDivider />
