---
import { site, formatPhone, fullAddress, resolveLinkHref } from "../config";

const year = new Date().getFullYear();
const footer = site.footer || {};
const columns = footer.columns || [];
const socialLinks = [
  { key: "facebook", label: "Facebook", href: site.contact?.facebook },
  { key: "instagram", label: "Instagram", href: site.contact?.instagram },
  { key: "tiktok", label: "TikTok", href: site.contact?.tiktok },
].filter((s) => s.href);
---

<footer class="border-t border-brand/10 bg-brand-dark py-14 text-gray-400">
  <div class="mx-auto max-w-6xl px-4 lg:px-8">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <span class="font-heading text-lg font-semibold text-white">{site.business?.name}</span>
        {(footer.tagline || site.business?.tagline) && (
          <p class="mt-2 text-sm leading-relaxed">{footer.tagline || site.business?.tagline}</p>
        )}
        {socialLinks.length > 0 && (
          <div class="mt-4 flex gap-3">
            {socialLinks.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-white/60 transition hover:text-white"
              >
                {s.label}
              </a>
            ))}
          </div>
        )}
      </div>

      {columns.map((col: any) => (
        <div>
          <h4 class="text-sm font-semibold text-white">{col.heading}</h4>
          <ul class="mt-3 space-y-2 text-sm">
            {col.links?.map((link: any) => (
              <li>
                <a href={resolveLinkHref(link.href)} class="transition hover:text-white">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-white/10 pt-6 text-center text-xs">
      <p>
        &copy; {year} {site.business?.name}. All rights reserved.
        {site.business?.abn && ` ABN ${site.business.abn}.`}
        {footer.copyrightSuffix}
      </p>
      {site.contact?.phone && (
        <p class="mt-2">
          <a href={`tel:${formatPhone(site.contact.phone)}`} class="transition hover:text-white">
            {site.contact.phone}
          </a>
          {site.contact?.email && (
            <>
              {" · "}
              <a href={`mailto:${site.contact.email}`} class="transition hover:text-white">
                {site.contact.email}
              </a>
            </>
          )}
        </p>
      )}
      {fullAddress() && <p class="mt-1 text-white/50">{fullAddress()}</p>}
    </div>
  </div>
</footer>
